# BFAM Sales Intelligence Platform — Environment Config
# Copy this to .env and fill in all values

# ── MySQL ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bfam_sales
DB_USER=bfam_user
DB_PASSWORD=bfam_demo_2026

# ── JWT ────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_long_random_string_minimum_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── App ────────────────────────────────────────────────
CORS_ORIGINS=*
APP_ENV=development
